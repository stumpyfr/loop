{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-loops.dev/schemas/loop.v1alpha1.schema.json",
  "title": "Loop",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec", "phases"],
  "properties": {
    "apiVersion": { "const": "agent-loops.dev/v1alpha1" },
    "kind": { "const": "AgentLoop" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "escalation": { "$ref": "#/$defs/escalation" }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "title", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objective", "inputs"],
      "properties": {
        "objective": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/input" }
        },
        "dependencies": { "$ref": "#/$defs/dependencies" }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["loops"] },
        { "required": ["skills"] }
      ],
      "properties": {
        "loops": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dependency" }
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dependency" }
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ref"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ref": {
          "type": "string",
          "pattern": "^[^\\s/@]+/[^\\s@]+(?:(?::[A-Za-z0-9_][A-Za-z0-9_.-]{0,127})|(?:@[A-Za-z][A-Za-z0-9_+.-]*:[A-Za-z0-9=_-]+)|(?::[A-Za-z0-9_][A-Za-z0-9_.-]{0,127}@[A-Za-z][A-Za-z0-9_+.-]*:[A-Za-z0-9=_-]+))$"
        },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "required", "description"],
      "properties": {
        "type": { "$ref": "#/$defs/typeDescriptor" },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "objective", "actions", "completion", "outputs"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "completion": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/output" }
        },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transition" }
        }
      }
    },
    "output": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "$ref": "#/$defs/typeDescriptor" },
          { "$ref": "#/$defs/stringEnum" }
        ]
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["to", "condition"],
      "properties": {
        "to": { "type": "string", "minLength": 1 },
        "condition": { "type": "string", "minLength": 1 }
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principle", "escalation_inputs"],
      "properties": {
        "principle": { "type": "string", "minLength": 1 },
        "escalation_inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/escalationInput" }
        }
      }
    },
    "escalationInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/typeDescriptor" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "typeDescriptor": {
      "oneOf": [
        { "enum": ["string", "number", "boolean", "object"] },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "enum": ["string", "number", "boolean", "object"] }
        }
      ]
    },
    "stringEnum": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
